<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="5dp"
    android:padding="10dp"
    android:background="@android:color/white">

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="20dp"
        android:background="@color/light_gray"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <!-- Hình ảnh món ăn -->
        <ImageView
            android:id="@+id/imgFoodCart"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="10dp">
            <!-- Tên món ăn -->
            <TextView
                android:id="@+id/tvFoodNameCart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên món"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Topping (có thể để trống nếu không có) -->
            <TextView
                android:id="@+id/tvFoodToppingCart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Topping: Không có"
                android:textSize="14sp"
                android:textColor="@android:color/darker_gray" />

            <!-- Giá món ăn -->
            <TextView
                android:id="@+id/tvFoodPriceCart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50.000 đ"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/holo_red_dark" />
        </LinearLayout>

        <!-- Số lượng món ăn -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnDecrease"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:backgroundTint="@color/white"
                android:text="-"
                android:padding="2dp"
                android:textColor="#212121"
                android:textSize="16sp"
                tools:ignore="TouchTargetSizeCheck" />

            <TextView
                android:id="@+id/tvFoodQuantityCart"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="1"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnIncrease"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:backgroundTint="@color/white"
                android:text="+"
                android:padding="2dp"
                android:textColor="#212121"
                android:textSize="16sp"
                tools:ignore="TouchTargetSizeCheck" />
        </LinearLayout>

        <!-- Nút xóa món khỏi giỏ hàng -->
        <ImageView
            android:id="@+id/btnRemoveCartItem"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@android:drawable/ic_delete"
            android:layout_marginStart="10dp"
            app:tint="@android:color/holo_red_dark" />
    </LinearLayout>
</LinearLayout>
