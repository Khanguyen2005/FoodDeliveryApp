<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Thêm món"
        android:textSize="20sp"
        android:gravity="center"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="10dp"
        android:paddingVertical="15dp"
        android:orientation="horizontal"
        android:background="@color/white">
        <ImageView
            android:id="@+id/img_food"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_launcher"
            android:background="@drawable/rounded_corner"
            android:clipToOutline="true"
            />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:orientation="vertical">
            <TextView
                android:id="@+id/food_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textSize="22sp"
                android:textColor="@color/black"
                android:layout_toEndOf="@+id/img_res"
                android:maxLines="1"
                android:ellipsize="end"
                />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@+id/img_food"
                android:layout_centerVertical="true"
                >
                <ImageView
                    android:id="@+id/imageView"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    app:srcCompat="@drawable/order_completed_svgrepo_com" />
                <TextView
                    android:id="@+id/quantitySold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:layout_gravity="center"
                    android:layout_marginLeft="5dp"
                    />

            </LinearLayout>
            <TextView
                android:id="@+id/price_food"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/color_main"
                android:layout_toEndOf="@+id/img_res"
                />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="5dp">

                <TextView
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:text="-"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/rounded_corner"
                    android:backgroundTint="#E9DCC9"
                    android:gravity="center"
                    android:textColor="@color/color_main"
                    android:textSize="24sp"
                    />

                <!-- TextView Hiển thị số lượng -->
                <TextView
                    android:id="@+id/txtQuantity"
                    android:layout_width="40dp"
                    android:layout_height="35dp"
                    android:text="1"
                    android:gravity="center"
                    android:textColor="@color/black"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:text="+"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/rounded_corner"
                    android:backgroundTint="@color/color_main"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
    <!-- 🔹 Container chứa danh sách toppings -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_weight="1"
        android:layout_height="0dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/toppingContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingBottom="16dp">
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 🔹 Nút "Thêm vào giỏ hàng" -->
    <Button
        android:id="@+id/btnAddToCart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Thêm vào giỏ hàng"
        android:backgroundTint="@color/color_main"
        android:textColor="@android:color/white"
        android:padding="12dp"
        android:textSize="16sp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="16dp"/> <!-- 🔹 Đặt khoảng cách 16dp với ViewGroup -->
</LinearLayout>
